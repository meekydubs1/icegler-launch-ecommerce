<style>
body[data-page="search"] .search-head{padding-top:calc(var(--nav-h) + clamp(40px,7vh,72px));}
body[data-page="search"] .search-form{
  display:flex; align-items:flex-end; gap:16px; margin-top:clamp(28px,4vh,44px); max-width:640px;
}
body[data-page="search"] .search-form .field{flex:1;}
body[data-page="search"] .search-grid{
  display:grid; grid-template-columns:repeat(3,minmax(0,1fr));
  gap:clamp(20px,3vw,44px); margin-top:clamp(44px,6vh,80px); align-items:start;
}
body[data-page="search"] .search-rows{margin-top:clamp(40px,5vh,64px);}
body[data-page="search"] .search-row{
  display:flex; justify-content:space-between; gap:24px; align-items:baseline;
  padding-block:22px; border-top:1px solid var(--mist);
}
body[data-page="search"] .search-rows .search-row:last-child{border-bottom:1px solid var(--mist);}
body[data-page="search"] .search-empty{padding-block:clamp(56px,10vh,110px);}
@media (max-width:920px){body[data-page="search"] .search-grid{grid-template-columns:1fr 1fr;}}
@media (max-width:560px){
  body[data-page="search"] .search-grid{grid-template-columns:1fr;}
  body[data-page="search"] .search-form{flex-direction:column; align-items:stretch;}
}
</style>

<section class="section search-head" aria-label="Search">
  <div class="container">
    <p class="eyebrow" data-reveal>Search</p>
    <h1 class="d-l" style="margin-top:16px;" data-reveal>Find your <em>light.</em></h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form" data-reveal>
      <div class="field">
        <label for="search-input">Search</label>
        <input type="search" id="search-input" name="q" value="{{ search.terms | escape }}" placeholder="Frames, colours, stories…" autocomplete="off">
      </div>
      <button class="btn btn-primary" type="submit">Search</button>
    </form>

    {%- if search.performed and search.results_count > 0 -%}
      <p class="coord" style="margin-top:26px;">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for &ldquo;{{ search.terms | escape }}&rdquo;</p>
    {%- endif -%}
  </div>
</section>

{%- if search.performed -%}
<section class="section-tight" aria-label="Search results">
  <div class="container">
    {%- if search.results_count == 0 -%}
      <div class="search-empty">
        <p class="d-m">Nothing surfaced.</p>
        <p class="coord" style="margin-top:14px;">No matches for &ldquo;{{ search.terms | escape }}&rdquo; — try another word.</p>
      </div>
    {%- else -%}
      {%- paginate search.results by 12 -%}
        {%- assign has_products = false -%}
        {%- assign has_other = false -%}
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- assign has_products = true -%}
          {%- else -%}
            {%- assign has_other = true -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_products -%}
        <div class="search-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- endif -%}

        {%- if has_other -%}
        <div class="search-rows">
          {%- for item in search.results -%}
            {%- unless item.object_type == 'product' -%}
              <div class="search-row">
                <a class="link-underline" href="{{ item.url }}">{{ item.title }}</a>
                <span class="coord">{{ item.object_type }}</span>
              </div>
            {%- endunless -%}
          {%- endfor -%}
        </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
        <nav class="coord" style="display:flex; gap:22px; justify-content:center; padding-top:48px;" aria-label="Pagination">
          {%- if paginate.previous -%}<a class="link-underline" href="{{ paginate.previous.url }}">← Previous</a>{%- endif -%}
          <span>Page {{ paginate.current_page }} / {{ paginate.pages }}</span>
          {%- if paginate.next -%}<a class="link-underline" href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
        </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{"name":"Search","settings":[]}
{% endschema %}
