}
body[data-page="lookbook"] .plate.on-light::after{
  background:linear-gradient(183deg, rgba(20,45,55,.14) 0%, rgba(20,45,55,0) 24%,
    rgba(20,45,55,0) 66%, rgba(20,45,55,.16) 100%);
}

/* ---- plate 01: full-bleed hero plate ---- */
body[data-page="lookbook"] .plate-hero{aspect-ratio:16/8.5;}
@media (max-width:920px){body[data-page="lookbook"] .plate-hero{aspect-ratio:4/3.4;}}

/* ---- two-up ---- */
body[data-page="lookbook"] .two-up{
  display:grid; grid-template-columns:1.15fr .85fr; gap:var(--plate-gap); align-items:start;
}
body[data-page="lookbook"] .two-up .plate{aspect-ratio:4/4.5;}
