}
body[data-page="lookbook"] .cover-title{max-width:none;}
body[data-page="lookbook"] .cover .d-xl{margin-top:22px;}
body[data-page="lookbook"] .cover-lead{margin-top:34px; max-width:40ch; color:var(--snow-dim);}
body[data-page="lookbook"] .cover-foot{
