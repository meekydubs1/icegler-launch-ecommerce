  margin-top:clamp(40px,8vh,88px); padding-top:20px;
  border-top:1px solid var(--hairline-dark); flex-wrap:wrap;
}

/* ---- intro: asymmetric pull-quote + notes ---- */
body[data-page="lookbook"] .intro-grid{
  display:grid; grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr);
  gap:clamp(40px,6vw,110px); align-items:start;
}
body[data-page="lookbook"] .intro-quote{
  font-family:var(--font-serif); font-weight:320; font-style:italic; font-optical-sizing:auto;
  font-size:clamp(26px,3.5vw,50px); line-height:1.16; letter-spacing:-.014em;
  position:relative; padding-left:.66em;
}
body[data-page="lookbook"] .intro-quote::before{
  content:"\201C"; position:absolute; left:-.06em; top:.02em;
  color:var(--ice); font-style:italic;
}
body[data-page="lookbook"] .intro-notes{padding-top:clamp(10px,3vh,40px);}
body[data-page="lookbook"] .intro-notes p{margin-top:20px; max-width:42ch;}
body[data-page="lookbook"] .intro-notes p:first-of-type{margin-top:26px;}

/* ---- shared scene plate ---- */
body[data-page="lookbook"] .plate{
  display:block; /* <a> plates must blockify or aspect-ratio collapses them */
  position:relative; overflow:hidden; isolation:isolate; border-radius:var(--r);
  text-decoration:none;
}
body[data-page="lookbook"] .plate .plate-media{
  position:absolute; inset:0; z-index:2; display:grid; place-items:center;
  mix-blend-mode:multiply;
}
body[data-page="lookbook"] .plate .plate-media img{
  width:78%; height:78%; object-fit:contain;
}
/* on dusk plates the photo mounts as a light print — screen/multiply both fail
   against white studio backgrounds on dark fields */
body[data-page="lookbook"] .plate.on-dusk .plate-media{mix-blend-mode:normal;}
body[data-page="lookbook"] .plate.on-dusk .plate-media img{
  width:min(56%,400px); height:auto; aspect-ratio:1; object-fit:cover;
  background:linear-gradient(158deg,#F7FBFC 0%,#E9F1F3 100%);
  border-radius:3px;
  box-shadow:0 44px 90px -32px rgba(0,0,0,.58), 0 10px 26px -12px rgba(0,0,0,.35);
}
body[data-page="lookbook"] .plate .plate-num{
  position:absolute; z-index:4; top:clamp(16px,2vw,26px); left:clamp(16px,2vw,26px);
  font-family:var(--font-serif); font-weight:340; line-height:.8;
  font-size:clamp(40px,5vw,76px); letter-spacing:-.02em;
  color:transparent; -webkit-text-stroke:1px rgba(252,253,253,.34);
}
