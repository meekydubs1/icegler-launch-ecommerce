/* ---- iceblock moment (04) ---- */
body[data-page="lookbook"] .signature-grid{
  display:grid; grid-template-columns:minmax(0,.92fr) minmax(0,1.08fr);
  gap:clamp(40px,6vw,96px); align-items:center;
}
body[data-page="lookbook"] .signature-copy .d-l{margin-top:20px;}
body[data-page="lookbook"] .signature-copy .lead{margin-top:24px; max-width:40ch; color:var(--snow-dim);}
body[data-page="lookbook"] .signature-copy .coord{margin-top:34px; display:block;}
body[data-page="lookbook"] .signature-ice .iceblock{
  aspect-ratio:5/4.4; max-width:560px; margin-inline:auto; border-radius:12px;
}
body[data-page="lookbook"] .signature-ice .iceblock-media{padding:9%;}
body[data-page="lookbook"] .signature-ice .melt-floor{max-width:560px; margin-inline:auto;}
body[data-page="lookbook"] .signature-ice .sig-cap{
  display:flex; justify-content:space-between; margin:8px auto 0; max-width:560px;
}

/* ---- offset two (05 / 06) ---- */
body[data-page="lookbook"] .offset-grid{
  display:grid; grid-template-columns:1fr 1fr; gap:var(--plate-gap); align-items:start;
}
body[data-page="lookbook"] .offset-grid .o-5{aspect-ratio:5/5.6;}
body[data-page="lookbook"] .offset-grid .o-6{aspect-ratio:5/6.4; margin-top:clamp(40px,8vh,110px);}
