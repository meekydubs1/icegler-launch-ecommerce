body[data-page="lookbook"] .plate .plate-cap{
  position:absolute; z-index:4; left:clamp(16px,2vw,26px); bottom:clamp(16px,2vw,26px);
  right:clamp(16px,2vw,26px);
  display:flex; justify-content:space-between; align-items:flex-end; gap:18px; flex-wrap:wrap;
}
body[data-page="lookbook"] .plate .plate-shop{
  color:var(--snow); font-weight:600; font-size:14px;
  display:inline-flex; align-items:center; gap:8px;
}
body[data-page="lookbook"] .plate.on-light .plate-shop{color:var(--basalt);}
body[data-page="lookbook"] .plate .plate-shop .arr{transition:transform .25s var(--ease);}
body[data-page="lookbook"] .plate .plate-shop:hover .arr{transform:translateX(5px);}
body[data-page="lookbook"] .plate .plate-label{
  font-family:var(--font-mono); font-weight:500; font-size:11.5px;
  letter-spacing:.16em; text-transform:uppercase; color:rgba(252,253,253,.72);
}
body[data-page="lookbook"] .plate.on-light .plate-label{color:var(--slate);}
/* frost vignette so type reads over any scene */
body[data-page="lookbook"] .plate::after{
  content:""; position:absolute; inset:0; z-index:3; pointer-events:none;
  background:linear-gradient(183deg, rgba(13,24,30,.32) 0%, rgba(13,24,30,0) 22%,
