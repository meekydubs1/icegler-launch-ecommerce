}
body[data-page="lookbook"] .tri-grid .plate{aspect-ratio:4/5.2;}
body[data-page="lookbook"] .tri-grid .t-8{margin-top:clamp(40px,8vh,96px);}
body[data-page="lookbook"] .tri-grid .t-9{margin-top:clamp(18px,3vh,44px);}

/* ---- closing driftwood band ---- */
body[data-page="lookbook"] .close-band{position:relative; overflow:hidden;}
body[data-page="lookbook"] .close-grid{
  display:grid; grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr);
  gap:clamp(40px,6vw,96px); align-items:end;
}
body[data-page="lookbook"] .close-line{
  font-family:var(--font-serif); font-weight:300; font-optical-sizing:auto;
  font-size:clamp(38px,5.4vw,78px); line-height:1.0; letter-spacing:-.022em;
}
body[data-page="lookbook"] .close-line em{font-style:italic; font-weight:300;}
body[data-page="lookbook"] .close-cta{display:flex; flex-direction:column; align-items:flex-start; gap:18px;}
body[data-page="lookbook"] .close-cta .coord{color:var(--slate);}
body[data-page="lookbook"] .close-ghost{
  position:absolute; right:clamp(-20px,-1vw,0px); bottom:-.16em; z-index:0;
  pointer-events:none; user-select:none; line-height:.8;
}

/* ---- responsive ---- */
@media (max-width:920px){
  body[data-page="lookbook"] .intro-grid{grid-template-columns:1fr; gap:44px;}
  body[data-page="lookbook"] .two-up{grid-template-columns:1fr; gap:32px;}
  body[data-page="lookbook"] .two-up .u-2{margin-top:0;}
  body[data-page="lookbook"] .signature-grid{grid-template-columns:1fr; gap:48px;}
  body[data-page="lookbook"] .signature-ice{order:-1;}
  body[data-page="lookbook"] .offset-grid{grid-template-columns:1fr; gap:32px;}
  body[data-page="lookbook"] .offset-grid .o-6{margin-top:0;}
  body[data-page="lookbook"] .tri-grid{grid-template-columns:1fr 1fr; gap:24px;}
  body[data-page="lookbook"] .tri-grid .t-8,body[data-page="lookbook"] .tri-grid .t-9{margin-top:0;}
  body[data-page="lookbook"] .close-grid{grid-template-columns:1fr; gap:40px; align-items:start;}
  body[data-page="lookbook"] .close-ghost{display:none;}
}
@media (max-width:560px){
  body[data-page="lookbook"] .cover-top{position:static; margin-bottom:auto;}
  body[data-page="lookbook"] .tri-grid{grid-template-columns:1fr; gap:20px;}
  body[data-page="lookbook"] .g-plate{flex-basis:82vw;}
}
