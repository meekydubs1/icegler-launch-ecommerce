<style>
body[data-page="404"] .lost{
  position:relative; min-height:100svh; display:flex; align-items:center; overflow:hidden;
  padding-block:calc(var(--nav-h) + 40px) 80px;
}
body[data-page="404"] .lost-code{
  position:absolute; right:-2%; bottom:-6%; z-index:1;
  font-size:clamp(180px,30vw,420px);
}
body[data-page="404"] .lost-copy{position:relative; z-index:2; max-width:640px;}
</style>

  <section class="lost section-dusk scene" aria-label="Page not found">
    <div class="aurora-veil"></div>
    <span class="ghost-num on-dark lost-code" data-parallax="0.1" aria-hidden="true">404</span>
    <div class="container lost-copy" data-reveal-group>
      <p class="eyebrow on-dark">64°08′46″N — nothing here</p>
      <h1 class="d-xl" style="margin-top:22px;">Lost in the <em>dusk.</em></h1>
      <p class="lead" style="margin-top:28px; max-width:44ch;">This page has melted away. The collection, though, is very much frozen in place.</p>
      <div style="display:flex; gap:22px; align-items:center; flex-wrap:wrap; margin-top:40px;">
        <a class="btn btn-ghost" href="{{ routes.root_url }}">Back to the light</a>
        <a class="link-arrow" href="{{ routes.all_products_collection_url }}" style="color:var(--snow);">Shop the collection <span class="arr">→</span></a>
      </div>
    </div>
  </section>

{% schema %}
{"name":"404","settings":[]}
{% endschema %}
