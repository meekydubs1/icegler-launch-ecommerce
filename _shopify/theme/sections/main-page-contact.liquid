<style>
/* ============ CONTACT ============ */
body[data-page="contact"] .contact-hero{padding-bottom:clamp(48px,7vh,84px);}
body[data-page="contact"] .contact-hero-grid{
  display:grid; grid-template-columns:minmax(0,8fr) minmax(0,4fr);
  gap:clamp(32px,5vw,72px); align-items:end;
}
body[data-page="contact"] .contact-hero .d-xl{margin-top:20px;}
body[data-page="contact"] .contact-hero-lead{max-width:34ch; padding-bottom:6px;}

/* locations split */
body[data-page="contact"] .loc-grid{
  display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr);
  gap:clamp(40px,6vw,96px); align-items:start;
}
body[data-page="contact"] .loc-block + .loc-block{
  padding-top:clamp(40px,5vh,56px); margin-top:clamp(40px,5vh,56px);
  border-top:1px solid var(--mist);
}
body[data-page="contact"] .loc-kind{
  display:inline-flex; align-items:center; gap:8px; margin-bottom:22px;
}
body[data-page="contact"] .loc-kind i{width:7px; height:7px; border-radius:50%; background:var(--glacial); flex:none;}
body[data-page="contact"] .loc-block h2{margin-top:0;}
body[data-page="contact"] .loc-addr{margin-top:18px; font-size:17px; line-height:1.55;}
body[data-page="contact"] .loc-addr span{display:block;}
body[data-page="contact"] .loc-coord{margin-top:14px; display:block;}
body[data-page="contact"] .spec-table{margin-top:26px;}
body[data-page="contact"] .loc-links{display:flex; flex-wrap:wrap; gap:20px 28px; margin-top:24px;}

/* the form column */
body[data-page="contact"] .form-col{position:relative;}
body[data-page="contact"] .contact-form{display:grid; gap:26px; margin-top:32px;}
body[data-page="contact"] .form-row-2{display:grid; grid-template-columns:1fr 1fr; gap:26px;}
body[data-page="contact"] .form-submit-row{
  display:flex; align-items:center; gap:20px; margin-top:6px; flex-wrap:wrap;
}
body[data-page="contact"] .form-note{color:var(--ash); font-size:13px;}

/* success state */
body[data-page="contact"] .form-success{
  display:grid; gap:18px; padding-top:clamp(28px,5vh,56px);
  min-height:420px; align-content:center;
}
body[data-page="contact"] .form-success[hidden]{display:none;}
body[data-page="contact"] .success-mark{
  width:52px; height:52px; border-radius:50%; border:1px solid var(--glacial);
  display:grid; place-items:center; color:var(--glacial);
  opacity:0; transform:scale(.7);
  transition:opacity .5s var(--ease-out), transform .5s var(--ease-out);
}
body[data-page="contact"] .form-success.in .success-mark{opacity:1; transform:none;}
body[data-page="contact"] .success-mark svg{width:22px; height:22px; stroke:currentColor; stroke-width:1.6; fill:none;}
body[data-page="contact"] .form-success .d-m{
  opacity:0; transform:translateY(14px);
  transition:opacity .6s var(--ease-out) .1s, transform .6s var(--ease-out) .1s;
}
body[data-page="contact"] .form-success.in .d-m{opacity:1; transform:none;}
body[data-page="contact"] .form-success p.lead{
  max-width:42ch; opacity:0; transform:translateY(14px);
  transition:opacity .6s var(--ease-out) .2s, transform .6s var(--ease-out) .2s;
}
body[data-page="contact"] .form-success.in p.lead{opacity:1; transform:none;}
body[data-page="contact"] .form-success .link-arrow{
  margin-top:6px; opacity:0; transform:translateY(14px);
  transition:opacity .6s var(--ease-out) .3s, transform .6s var(--ease-out) .3s;
}
body[data-page="contact"] .form-success.in .link-arrow{opacity:1; transform:none;}

/* ice-field accent strip */
body[data-page="contact"] .accent-strip{
  position:relative; min-height:clamp(220px,32vh,340px);
  display:flex; align-items:center;
}
body[data-page="contact"] .accent-strip .accent-inner{position:relative; z-index:2; width:100%;}
body[data-page="contact"] .accent-strip .d-m{max-width:20ch;}
body[data-page="contact"] .accent-coord{
  position:absolute; right:clamp(20px,5vw,72px); bottom:26px; z-index:2;
}

/* stockists table */
body[data-page="contact"] .stockist-head{
  display:flex; justify-content:space-between; align-items:flex-end; gap:32px; flex-wrap:wrap;
}
body[data-page="contact"] .stockist-table{width:100%; border-collapse:collapse; margin-top:clamp(36px,5vh,52px);}
body[data-page="contact"] .stockist-table th{
  text-align:left; font-family:var(--font-mono); font-weight:500; font-size:11.5px;
  letter-spacing:.14em; text-transform:uppercase; color:var(--ash);
  padding:0 16px 14px 0; border-bottom:1px solid var(--mist);
}
body[data-page="contact"] .stockist-table td{
  padding:20px 16px 20px 0; border-bottom:1px solid var(--mist); vertical-align:top;
  font-size:15px;
}
body[data-page="contact"] .stockist-table tr:last-child td{border-bottom:0;}
body[data-page="contact"] .stockist-table td.mono-cell{font-family:var(--font-mono); font-size:13px; color:var(--slate); white-space:nowrap;}
body[data-page="contact"] .stockist-name{font-weight:600;}
body[data-page="contact"] .stockist-badge{
  display:inline-block; font-family:var(--font-mono); font-size:10px; font-weight:500;
  letter-spacing:.14em; text-transform:uppercase; padding:3px 8px; border-radius:var(--r);
  color:var(--snow); background:var(--ash);
}
body[data-page="contact"] .stockist-badge.flagship{background:var(--glacial);}
body[data-page="contact"] .stockist-table td.addr-cell{color:var(--slate);}

@media (max-width:920px){
  body[data-page="contact"] .contact-hero-grid{grid-template-columns:1fr; gap:24px;}
  body[data-page="contact"] .contact-hero-lead{max-width:none;}
  body[data-page="contact"] .loc-grid{grid-template-columns:1fr; gap:0;}
  body[data-page="contact"] .form-col{padding-top:clamp(40px,5vh,56px); margin-top:clamp(40px,5vh,56px); border-top:1px solid var(--mist);}
  body[data-page="contact"] .form-row-2{grid-template-columns:1fr; gap:26px;}
  body[data-page="contact"] .stockist-table{font-size:14px;}
  body[data-page="contact"] .stockist-table th:nth-child(4),
  body[data-page="contact"] .stockist-table td:nth-child(4){display:none;}
}
@media (max-width:560px){
  body[data-page="contact"] .stockist-table th:nth-child(2),
  body[data-page="contact"] .stockist-table td:nth-child(2){display:none;}
  body[data-page="contact"] .form-submit-row{flex-direction:column; align-items:stretch;}
}
</style>

  <!-- ══════════ HEADER ══════════ -->
  <section class="section contact-hero" aria-label="Introduction">
    <div class="container contact-hero-grid">
      <div data-reveal-group>
        <p class="eyebrow">Contact · Stores · FAQ</p>
        <h1 class="d-xl">We'd love to<br>hear from <em>you.</em></h1>
      </div>
      <p class="lead contact-hero-lead" data-reveal data-reveal-delay="120">A small team in Reykjavík, happy to help with fit, lenses, orders, or anything else. We reply within one working day.</p>
    </div>
  </section>

  <!-- ══════════ LOCATIONS + FORM ══════════ -->
  <section class="section section-tight" aria-label="Studio, flagship store and contact form">
    <div class="container loc-grid">

      <!-- left: studio + flagship -->
      <div>
        <div class="loc-block" data-reveal>
          <div class="loc-kind"><i aria-hidden="true"></i><span class="eyebrow quiet">The studio</span></div>
          <h2 class="h2">Where the frames<br>are drawn.</h2>
          <address class="loc-addr" style="font-style:normal;">
            <span>Grandagarður 7</span>
            <span>101 Reykjavík, Iceland</span>
          </address>
          <span class="coord loc-coord">64°09′05″N — 21°56′55″W</span>
          <table class="spec-table" aria-label="Studio hours">
            <tbody>
              <tr><th scope="row">Hours</th><td>Mon–Fri · 9:00–17:00 GMT</td></tr>
              <tr><th scope="row">Email</th><td><a class="link-underline" href="#">hello@icegler.is</a></td></tr>
              <tr><th scope="row">Phone</th><td><a class="link-underline" href="#">+354 555 0142</a></td></tr>
            </tbody>
          </table>
        </div>

        <div class="loc-block" data-reveal>
          <div class="loc-kind"><i aria-hidden="true"></i><span class="eyebrow quiet">The flagship</span></div>
          <h2 class="h2">Where you can<br>try them on.</h2>
          <address class="loc-addr" style="font-style:normal;">
            <span>Laugavegur 42</span>
            <span>101 Reykjavík, Iceland</span>
          </address>
          <span class="coord loc-coord">64°08′46″N — 21°56′24″W</span>
          <table class="spec-table" aria-label="Flagship store hours">
            <tbody>
              <tr><th scope="row">Hours</th><td>Daily · 10:00–18:00</td></tr>
              <tr><th scope="row">Fittings</th><td>Walk-in or by appointment</td></tr>
            </tbody>
          </table>
          <div class="loc-links">
            <a class="link-underline" href="#">Email the studio</a>
            <a class="link-underline" href="{{ routes.all_products_collection_url }}">Shop the collection</a>
          </div>
        </div>
      </div>

      <!-- right: form -->
      <div class="form-col" data-reveal data-reveal-delay="120">
        <p class="eyebrow">Send a message</p>

        {%- form 'contact', class: 'contact-form', id: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-success in">
              <div class="success-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M4 12.5l5.5 5.5L20 6.5"/></svg>
              </div>
              <p class="d-m">Message sent.</p>
              <p class="lead">Thank you. We've got your note and will reply within one working day.</p>
              <a class="link-arrow" href="/pages/contact">Send another <span class="arr">→</span></a>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <p class="field-error" role="alert">Something didn't go through. Please check the fields and try again.</p>
            {%- endif -%}
            <div class="form-row-2">
              <div class="field" data-field="name">
                <label for="c-name">Name</label>
                <input id="c-name" name="contact[name]" type="text" placeholder="Your name" autocomplete="name" required>
                <p class="field-error" hidden>Please tell us your name.</p>
              </div>
              <div class="field" data-field="email">
                <label for="c-email">Email</label>
                <input id="c-email" name="contact[email]" type="email" placeholder="your@email.com" autocomplete="email" required>
                <p class="field-error" hidden>Please enter a valid email.</p>
              </div>
            </div>

            <div class="field" data-field="subject">
              <label for="c-subject">Subject</label>
              <select id="c-subject" name="contact[topic]">
                <option>A question about fit</option>
                <option>Lenses &amp; prescriptions</option>
                <option>An existing order</option>
                <option>Press &amp; partnerships</option>
                <option>Something else</option>
              </select>
            </div>

            <div class="field" data-field="message">
              <label for="c-message">Message</label>
              <textarea id="c-message" name="contact[body]" placeholder="How can we help?" required></textarea>
              <p class="field-error" hidden>Tell us a little about how we can help.</p>
            </div>

            <div class="form-submit-row">
              <button class="btn btn-primary" type="submit">Send message</button>
              <span class="form-note">We reply within one working day.</span>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>
  </section>

  <!-- ══════════ ICE-FIELD ACCENT STRIP ══════════ -->
  <section class="accent-strip ice-field scene bleed" aria-hidden="true">
    <div class="container accent-inner">
      <p class="d-m">Clarity, even<br>from a distance.</p>
    </div>
    <span class="coord accent-coord" data-parallax="0.08">64°08′N — 21°56′W</span>
  </section>

  <!-- ══════════ STOCKISTS ══════════ -->
  <section class="section" aria-label="Stores and stockists">
    <div class="container">
      <div class="stockist-head" data-reveal>
        <div>
          <p class="eyebrow">Find us</p>
          <h2 class="d-l" style="margin-top:16px;">Stores &amp;<br>stockists.</h2>
        </div>
        <p class="lead" style="max-width:34ch;">Try a frame in person — our own stores in Iceland, and stockists across Europe.</p>
      </div>

      <table class="stockist-table" data-reveal>
        <thead>
          <tr>
            <th scope="col">Store</th>
            <th scope="col">Country</th>
            <th scope="col">Address</th>
            <th scope="col">Hours</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="stockist-badge flagship">Flagship</span> <span class="stockist-name">Icegler Reykjavík</span></td>
            <td>Iceland</td>
            <td class="addr-cell">Laugavegur 42, 101 Reykjavík</td>
            <td class="mono-cell">Daily · 10–18</td>
          </tr>
          <tr>
            <td><span class="stockist-badge">Store</span> <span class="stockist-name">Icegler Akureyri</span></td>
            <td>Iceland</td>
            <td class="addr-cell">Hafnarstræti 91, 600 Akureyri</td>
            <td class="mono-cell">Mon–Sat · 11–17</td>
          </tr>
          <tr>
            <td><span class="stockist-badge">Stockist</span> <span class="stockist-name">Designhús</span></td>
            <td>Denmark</td>
            <td class="addr-cell">Bredgade 12, 1260 Copenhagen</td>
            <td class="mono-cell">Mon–Sat · 10–18</td>
          </tr>
          <tr>
            <td><span class="stockist-badge">Stockist</span> <span class="stockist-name">Optik Mitte</span></td>
            <td>Germany</td>
            <td class="addr-cell">Torstraße 84, 10119 Berlin</td>
            <td class="mono-cell">Tue–Sat · 11–19</td>
          </tr>
          <tr>
            <td><span class="stockist-badge">Stockist</span> <span class="stockist-name">Galerie Optique</span></td>
            <td>France</td>
            <td class="addr-cell">18 Rue de Turenne, 75004 Paris</td>
            <td class="mono-cell">Mon–Sat · 11–19</td>
          </tr>
          <tr>
            <td><span class="stockist-badge">Stockist</span> <span class="stockist-name">Brillehuset</span></td>
            <td>Norway</td>
            <td class="addr-cell">Bogstadveien 6, 0355 Oslo</td>
            <td class="mono-cell">Mon–Fri · 10–18</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

{% schema %}
{"name":"Contact","settings":[]}
{% endschema %}
