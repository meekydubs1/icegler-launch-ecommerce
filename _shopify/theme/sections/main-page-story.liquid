      </div>
    </div>
  </section>

  <!-- ══════════ CLOSING — dusk band ══════════ -->
  <section class="section section-dusk scene closing" aria-label="See it for yourself">
    <div class="aurora-veil"></div>
    <div class="container closing-grid">
      <div data-reveal-group>
        <p class="eyebrow on-dark">See it for yourself</p>
        <h2 class="d-l" style="margin-top:18px;">We come from<br>the <em>cold.</em></h2>
        <p class="lead" style="margin-top:24px;">Three frames, made from the cold. Find the one that's yours.</p>
        <div class="closing-coord">
          <span class="coord">64°08′46″N — 21°56′24″W</span>
          <span class="coord">Reykjavík, Iceland</span>
        </div>
      </div>
      <div class="closing-cta" data-reveal data-reveal-delay="200">
        <a class="btn btn-ghost" href="{{ routes.all_products_collection_url }}" data-cursor="view">Explore the collection <span class="arr">→</span></a>
      </div>
    </div>
  </section>

<script>
/* Story page — timeline spine draw-in (the one orchestrated wow).
   One IntersectionObserver toggles .drawn on the track; CSS scaleY animates
   the hairline spine. Motion is skipped under reduced-motion (CSS shows the
   spine at full scale, so nothing is hidden). */
(function () {
  'use strict';
  var track = document.querySelector('body[data-page="story"] .tl-track');
  if (!track) return;
  if (document.documentElement.classList.contains('rm') || !('IntersectionObserver' in window)) {
    track.classList.add('drawn');
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (en) {
      if (en.isIntersecting) { track.classList.add('drawn'); io.unobserve(en.target); }
    });
  }, { rootMargin: '0px 0px -18% 0px', threshold: 0.12 });
  io.observe(track);
})();
</script>

