<style>
/* ============ STORY ============ */
/* — opener: three offset serif lines — */
body[data-page="story"] .story-open{
  padding-block:calc(var(--nav-h) + clamp(56px,11vh,132px)) clamp(56px,8vh,96px);
}
body[data-page="story"] .open-head{
  display:flex; justify-content:space-between; align-items:baseline; gap:24px; flex-wrap:wrap;
}
body[data-page="story"] .open-coord{color:var(--ash);}
body[data-page="story"] .open-title{
  margin-top:clamp(28px,5vh,54px); position:relative;
}
body[data-page="story"] .open-title .l1{display:block; margin-left:0;}
body[data-page="story"] .open-title .l2{display:block; margin-left:clamp(24px,10vw,180px);}
body[data-page="story"] .open-title .l3{display:block; margin-left:clamp(48px,20vw,360px);}
body[data-page="story"] .open-foot{
  display:grid; grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr);
  gap:clamp(32px,6vw,96px); align-items:end;
  margin-top:clamp(40px,7vh,80px); padding-top:clamp(28px,4vh,44px);
  border-top:1px solid var(--mist);
}
body[data-page="story"] .open-foot .lead{max-width:50ch;}
body[data-page="story"] .open-scene{
  position:relative; aspect-ratio:5/3.4; border-radius:var(--r); overflow:hidden;
}
body[data-page="story"] .open-scene .scene-label{
  position:absolute; left:16px; bottom:14px; z-index:4;
  color:rgba(252,253,253,.62);
}
body[data-page="story"] .open-scene .scene-quote{
  position:absolute; inset:auto 8% 22% 8%; z-index:4;
  font-family:var(--font-serif); font-weight:320; font-style:italic;
  font-size:clamp(17px,2vw,24px); line-height:1.32; color:var(--snow);
  text-wrap:balance; max-width:26ch;
}

/* — driftwood founding pull-quote — */
body[data-page="story"] .founding{position:relative; overflow:hidden;}
body[data-page="story"] .founding .ghost-mark{
  position:absolute; left:clamp(-12px,-1vw,-4px); top:clamp(-38px,-6vh,-70px); z-index:0;
  font-family:var(--font-serif); font-style:italic; font-weight:340; line-height:1;
  font-size:clamp(220px,34vw,460px); color:transparent;
  -webkit-text-stroke:1px rgba(21,25,27,.14); pointer-events:none; user-select:none;
}
body[data-page="story"] .founding-grid{
  position:relative; z-index:2;
  display:grid; grid-template-columns:minmax(0,.34fr) minmax(0,1fr);
  gap:clamp(24px,4vw,64px); align-items:start;
}
body[data-page="story"] .founding-grid .eyebrow{padding-top:14px;}
body[data-page="story"] .founding-quote{
  font-family:var(--font-serif); font-weight:320; font-optical-sizing:auto;
  font-size:clamp(28px,4vw,58px); line-height:1.14; letter-spacing:-.018em;
}
body[data-page="story"] .founding-quote .em{font-style:italic; font-weight:320; color:var(--glacial);}

/* — origin: sticky mono label + serif head + 2-col body — */
body[data-page="story"] .origin-grid{
  display:grid; grid-template-columns:minmax(0,.26fr) minmax(0,1fr);
  gap:clamp(28px,5vw,80px); align-items:start;
}
body[data-page="story"] .origin-label{position:sticky; top:calc(var(--nav-h) + 28px);}
body[data-page="story"] .origin-body{max-width:70ch;}
body[data-page="story"] .origin-cols{
  columns:2; column-gap:clamp(28px,4vw,64px);
  margin-top:clamp(28px,4vh,44px);
}
body[data-page="story"] .origin-cols p{break-inside:avoid; margin-bottom:1.15em;}
body[data-page="story"] .origin-cols p:last-child{margin-bottom:0;}

/* — the timeline (WOW: spine scales in) — */
body[data-page="story"] .timeline{position:relative;}
body[data-page="story"] .tl-head{max-width:46ch; margin-bottom:clamp(48px,7vh,84px);}
body[data-page="story"] .tl-track{position:relative; padding-block:8px;}
body[data-page="story"] .tl-spine{
  position:absolute; top:0; bottom:0; left:50%; width:1px; margin-left:-.5px; z-index:0;
  background:linear-gradient(180deg,
    rgba(219,224,225,0) 0%, var(--mist) 6%, var(--mist) 94%, rgba(219,224,225,0) 100%);
  transform:scaleY(0); transform-origin:top center;
  transition:transform 1.1s var(--ease-out);
}
body[data-page="story"] .tl-track.drawn .tl-spine{transform:scaleY(1);}
html.rm body[data-page="story"] .tl-spine{transform:scaleY(1); transition:none;}
body[data-page="story"] .tl-row{
  position:relative; z-index:2;
  display:grid; grid-template-columns:1fr 1fr; gap:clamp(32px,6vw,120px);
  padding-block:clamp(22px,4vh,44px);
}
body[data-page="story"] .tl-row .tl-cell{max-width:38ch;}
body[data-page="story"] .tl-row .tl-cell.left{grid-column:1; text-align:right; justify-self:end;}
body[data-page="story"] .tl-row .tl-cell.right{grid-column:2; justify-self:start;}
body[data-page="story"] .tl-year{
  font-family:var(--font-mono); font-weight:500; font-size:14px;
  letter-spacing:.16em; color:var(--glacial);
}
body[data-page="story"] .tl-row h3{margin-top:12px; font-size:21px;}
body[data-page="story"] .tl-row p{margin-top:10px; color:var(--slate); font-size:15.5px;}
body[data-page="story"] .tl-node{
  position:absolute; top:calc(clamp(22px,4vh,44px) + 6px); left:50%; z-index:3;
  width:11px; height:11px; margin-left:-5.5px; border-radius:50%;
  background:var(--snow); border:1px solid var(--glacial);
  box-shadow:0 0 0 5px var(--glacier);
}
body[data-page="story"] .tl-row.filled .tl-node{background:var(--glacial);}

/* — made-well material triptych — */
body[data-page="story"] .craft{background:linear-gradient(180deg,var(--snow) 0%,var(--meltwater) 100%);}
body[data-page="story"] .craft-head{
  display:grid; grid-template-columns:minmax(0,1fr) minmax(0,.72fr);
  gap:clamp(28px,5vw,80px); align-items:end;
}
body[data-page="story"] .craft-head .support{color:var(--slate); max-width:36ch; justify-self:end; text-align:right;}
body[data-page="story"] .triptych{
  display:grid; grid-template-columns:repeat(3,1fr); gap:clamp(24px,3vw,52px);
  margin-top:clamp(48px,7vh,90px);
}
body[data-page="story"] .mat{position:relative; padding-top:clamp(40px,6vh,72px);}
body[data-page="story"] .mat .ghost-num{
  position:absolute; top:clamp(-46px,-6vh,-88px); left:-.06em; z-index:0;
  font-size:clamp(96px,11vw,168px); -webkit-text-stroke:1px rgba(21,25,27,.15);
}
body[data-page="story"] .mat-inner{position:relative; z-index:2; border-top:1px solid rgba(21,25,27,.16); padding-top:22px;}
body[data-page="story"] .mat-eyebrow{color:var(--slate);}
body[data-page="story"] .mat h3{margin-top:14px; font-size:20px;}
body[data-page="story"] .mat p{margin-top:12px; color:var(--slate); font-size:15px;}

/* — conscience stat strip — */
body[data-page="story"] .stats-head{max-width:40ch; margin-bottom:clamp(44px,6vh,72px);}
body[data-page="story"] .stat-strip{
  display:grid; grid-template-columns:repeat(4,1fr); gap:clamp(20px,3vw,48px);
  border-top:1px solid var(--mist);
}
body[data-page="story"] .stat{padding-top:clamp(24px,3.5vh,40px); position:relative;}
body[data-page="story"] .stat:not(:first-child)::before{
  content:""; position:absolute; left:calc(clamp(20px,3vw,48px) / -2); top:0; bottom:22%;
  width:1px; background:var(--mist);
}
body[data-page="story"] .stat-num{
  font-family:var(--font-serif); font-weight:300; font-optical-sizing:auto;
  font-size:clamp(52px,6.5vw,92px); line-height:.92; letter-spacing:-.02em;
}
body[data-page="story"] .stat-num .u{font-size:.42em; letter-spacing:0; vertical-align:baseline;}
body[data-page="story"] .stat p:not(.stat-num){margin-top:18px; color:var(--slate); font-size:14.5px; max-width:22ch;}

/* — dusk closing band — */
body[data-page="story"] .closing{position:relative; overflow:hidden;}
body[data-page="story"] .closing-grid{
  display:grid; grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr);
  gap:clamp(36px,6vw,96px); align-items:center;
}
body[data-page="story"] .closing-grid .lead{max-width:42ch;}
body[data-page="story"] .closing-cta{justify-self:end;}
body[data-page="story"] .closing-coord{
  display:flex; gap:22px; align-items:center; margin-top:34px; flex-wrap:wrap;
}

/* — responsive — */
@media (max-width:920px){
  body[data-page="story"] .open-title .l2{margin-left:clamp(16px,6vw,64px);}
  body[data-page="story"] .open-title .l3{margin-left:clamp(32px,12vw,120px);}
  body[data-page="story"] .open-foot{grid-template-columns:1fr; gap:36px;}
  body[data-page="story"] .open-scene{aspect-ratio:5/3.6;}
  body[data-page="story"] .founding-grid{grid-template-columns:1fr; gap:28px;}
  body[data-page="story"] .founding-grid .eyebrow{padding-top:0;}
  body[data-page="story"] .founding .ghost-mark{font-size:clamp(200px,44vw,340px);}
  body[data-page="story"] .origin-grid{grid-template-columns:1fr; gap:32px;}
  body[data-page="story"] .origin-label{position:static;}
  body[data-page="story"] .origin-cols{columns:1;}
  body[data-page="story"] .craft-head{grid-template-columns:1fr; gap:24px;}
  body[data-page="story"] .craft-head .support{justify-self:start; text-align:left;}
  body[data-page="story"] .triptych{grid-template-columns:1fr; gap:44px;}
  body[data-page="story"] .mat{padding-top:0;}
  body[data-page="story"] .mat .ghost-num{position:static; display:block; margin-bottom:-.24em;}
  body[data-page="story"] .stat-strip{grid-template-columns:1fr 1fr; gap:0;}
  body[data-page="story"] .stat{padding:clamp(24px,4vh,36px) 0; border-top:1px solid var(--mist);}
  body[data-page="story"] .stat-strip{border-top:0;}
  body[data-page="story"] .stat:not(:first-child)::before{display:none;}
  body[data-page="story"] .stat:nth-child(odd){padding-right:clamp(20px,4vw,32px);}
  body[data-page="story"] .stat:nth-child(even){padding-left:clamp(20px,4vw,32px); border-left:1px solid var(--mist);}
  body[data-page="story"] .closing-grid{grid-template-columns:1fr; gap:36px;}
  body[data-page="story"] .closing-cta{justify-self:start;}

  /* timeline reflows to a single left rail */
  body[data-page="story"] .tl-spine{left:6px; margin-left:0;}
  body[data-page="story"] .tl-row{grid-template-columns:1fr; gap:0; padding-left:36px;}
  body[data-page="story"] .tl-row .tl-cell.left,
  body[data-page="story"] .tl-row .tl-cell.right{
    grid-column:1; text-align:left; justify-self:start; max-width:56ch;
  }
  body[data-page="story"] .tl-row .tl-cell.left{margin-bottom:clamp(18px,3vh,30px);}
  body[data-page="story"] .tl-node{left:6px; margin-left:-5px; box-shadow:0 0 0 5px var(--glacier);}
}
@media (max-width:560px){
  body[data-page="story"] .open-title .l1{margin-left:0;}
  body[data-page="story"] .open-title .l2{margin-left:14px;}
  body[data-page="story"] .open-title .l3{margin-left:28px;}
  body[data-page="story"] .stat-strip{grid-template-columns:1fr;}
  body[data-page="story"] .stat:nth-child(even){padding-left:0; border-left:0;}
}
</style>

  <!-- ══════════ OPENER — glacier light, three offset lines ══════════ -->
  <section class="section story-open" aria-label="Our story">
    <div class="container">
      <div class="open-head" data-reveal="fade">
        <p class="eyebrow">Our story — 64°08′N</p>
        <span class="coord open-coord">Reykjavík — Winter 25</span>
      </div>

      <h1 class="d-xl open-title" data-reveal="mask">
        <span class="l1">From the</span>
        <span class="l2">edge of</span>
        <span class="l3">the <em>map.</em></span>
      </h1>

      <div class="open-foot">
        <p class="lead" data-reveal data-reveal-delay="120">Icegler began in Reykjavík with a simple idea: that the clearest light in the world deserves eyewear made with the same clarity. We design from the cold, for anyone who lives in it.</p>

        <figure class="open-scene ice-field deep scene" data-reveal="scale" style="margin:0;">
          <div class="aurora-veil"></div>
          <p class="scene-quote">In winter the sun barely clears the horizon. The whole island turns the colour of a held breath.</p>
          <span class="coord scene-label">Glacier coast — the long blue dusk</span>
        </figure>
      </div>
    </div>
  </section>

  <!-- ══════════ FOUNDING PULL-QUOTE — driftwood band ══════════ -->
  <section class="section-tight section-drift founding" aria-label="The philosophy">
    <span class="ghost-mark" aria-hidden="true">&ldquo;</span>
    <div class="container founding-grid">
      <p class="eyebrow" data-reveal>The philosophy</p>
      <blockquote class="founding-quote" data-reveal data-reveal-delay="100" style="margin:0;">We make one promise: <span class="em">nothing hidden.</span> The frame you hold is exactly what it appears to be — clear material, honest craft, no shortcuts frozen&nbsp;inside.</blockquote>
    </div>
  </section>

  <!-- ══════════ ORIGIN — 01 The light ══════════ -->
  <section class="section" aria-label="The light">
    <div class="container origin-grid">
      <div class="origin-label">
        <p class="eyebrow">01 — The light</p>
      </div>
      <div class="origin-body" data-reveal>
        <h2 class="d-l">Iceland gives you two kinds of light, and nothing&nbsp;in between.</h2>
        <div class="origin-cols">
          <p>There is the long blue dusk of winter, when the day is a rumour and the snow does the work the sun won't. And there is the white, ceaseless light of summer, when the night never fully arrives and the glaciers throw it back at you from every angle.</p>
          <p>Both are hard on the eyes. Both are beautiful. We grew up squinting into them, and we built Icegler for exactly that — frames that earn their place on your face when the light is at its most extreme, and its most lovely.</p>
          <p>Every decision we make, from the curve of a lens to the weight of an arm, is measured against that standard: would it hold up to an Icelandic afternoon?</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ marquee ══════════ -->
  <div class="marquee" data-marquee>Designed in Reykjavík ◦ Shaped by Icelandic light ◦ Handcrafted bio-acetate ◦ Carl Zeiss polarized ◦ </div>

  <!-- ══════════ TIMELINE — the making, spine draws in (WOW) ══════════ -->
  <section class="section timeline" aria-label="How a frame is made">
    <div class="container">
      <div class="tl-head" data-reveal>
        <p class="eyebrow">02 — The iceblock, and the making</p>
        <h2 class="d-l" style="margin-top:16px;">Why we freeze our<br>frames in <em>ice.</em></h2>
        <p class="lead" style="margin-top:22px;">It started as a photograph — a pair of frames set inside a clear block of glacier ice, lit from behind. We loved what it said before we could explain it. Ice hides nothing. We want our frames to be read the same way.</p>
      </div>

      <div class="tl-track">
        <div class="tl-spine" aria-hidden="true"></div>

        <div class="tl-row filled" data-reveal>
          <div class="tl-cell left">
            <span class="tl-year">THE IDEA</span>
            <h3 class="h3">A photograph, lit from behind</h3>
            <p>A pair of frames set inside a clear block of glacier ice. We loved what it said before we could explain it — and it became our signature, and our standard.</p>
          </div>
          <div class="tl-node" aria-hidden="true"></div>
        </div>

        <div class="tl-row" data-reveal>
          <div class="tl-node" aria-hidden="true"></div>
          <div class="tl-cell right">
            <span class="tl-year">01 — MATERIAL</span>
            <h3 class="h3">Plant-based acetate</h3>
            <p>Our acetate is made from cotton and wood pulp, not oil. It cuts warmer, polishes glassier, and returns to the earth at the end of its long life.</p>
          </div>
        </div>

        <div class="tl-row filled" data-reveal>
          <div class="tl-cell left">
            <span class="tl-year">02 — LENS</span>
            <h3 class="h3">Carl Zeiss glass</h3>
            <p>Every pair leaves with German Zeiss glass — 100% UV400, polarized, and ground to cut the low, hard glare you only get this far north.</p>
          </div>
          <div class="tl-node" aria-hidden="true"></div>
        </div>

        <div class="tl-row" data-reveal>
          <div class="tl-node" aria-hidden="true"></div>
          <div class="tl-cell right">
            <span class="tl-year">03 — FINISH</span>
            <h3 class="h3">Hand-finished in Reykjavík</h3>
            <p>Tumbled for three days, hand-assembled, and inspected one frame at a time by the small team that designed it. Built to be kept, not replaced.</p>
          </div>
        </div>

        <div class="tl-row filled" data-reveal>
          <div class="tl-cell left">
            <span class="tl-year">THE MARK</span>
            <h3 class="h3">Clarity you can hold to the light</h3>
            <p>Look through ice and you see every bubble, every fracture, every honest flaw. A single frame passes through a dozen pairs of hands before it earns the Icegler mark.</p>
          </div>
          <div class="tl-node" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ MADE WELL — 03 material triptych, ghost numerals ══════════ -->
  <section class="section craft" aria-label="The making">
    <div class="container">
      <div class="craft-head" data-reveal-group>
