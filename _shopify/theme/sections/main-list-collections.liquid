<style>
body[data-page="list-collections"] .cols-head{padding-top:calc(var(--nav-h) + clamp(40px,7vh,72px));}
body[data-page="list-collections"] .cols-list{margin-top:clamp(44px,6vh,80px);}
body[data-page="list-collections"] .cols-row{
  display:flex; justify-content:space-between; align-items:baseline; gap:24px;
  padding-block:clamp(24px,3.5vh,40px); border-top:1px solid var(--mist); text-decoration:none;
}
body[data-page="list-collections"] .cols-list .cols-row:last-child{border-bottom:1px solid var(--mist);}
body[data-page="list-collections"] .cols-row .name{
  font-family:var(--font-serif); font-weight:340; font-size:clamp(24px,3vw,40px);
  line-height:1.05; letter-spacing:-.015em; transition:color .25s var(--ease);
}
body[data-page="list-collections"] .cols-row:hover .name{color:var(--glacial);}
body[data-page="list-collections"] .cols-row .name em{font-style:italic; font-weight:320;}
body[data-page="list-collections"] .cols-row .count{
  font-family:var(--font-mono); font-size:12px; color:var(--ash);
  white-space:nowrap; letter-spacing:.06em;
}
</style>

<section class="section cols-head" aria-label="Collections">
  <div class="container">
    <p class="eyebrow" data-reveal>Collections</p>
    <h1 class="d-l" style="margin-top:16px;" data-reveal>Every <em>frame,</em><br>by collection.</h1>

    {%- paginate collections by 20 -%}
    <div class="cols-list" data-reveal-group>
      {%- for collection in collections -%}
        <a class="cols-row" href="{{ collection.url }}" data-cursor="view">
          <span class="name">{{ collection.title }}</span>
          <span class="count">{{ collection.all_products_count }} {% if collection.all_products_count == 1 %}frame{% else %}frames{% endif %}</span>
        </a>
      {%- else -%}
        <p class="muted" style="padding-block:44px;">No collections yet.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
    <nav class="coord" style="display:flex; gap:22px; justify-content:center; padding-top:48px;" aria-label="Pagination">
      {%- if paginate.previous -%}<a class="link-underline" href="{{ paginate.previous.url }}">← Previous</a>{%- endif -%}
      <span>Page {{ paginate.current_page }} / {{ paginate.pages }}</span>
      {%- if paginate.next -%}<a class="link-underline" href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
    </nav>
    {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{"name":"Collections list","settings":[]}
{% endschema %}
