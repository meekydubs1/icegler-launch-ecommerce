<style>
body[data-page="article"] .article-head{padding-top:calc(var(--nav-h) + clamp(40px,7vh,72px));}
body[data-page="article"] .article-meta{display:flex; gap:18px; align-items:center; margin-top:22px; flex-wrap:wrap;}
body[data-page="article"] .article-prose{max-width:66ch; margin-top:clamp(36px,5vh,60px); color:var(--slate); font-size:17px; line-height:1.7;}
body[data-page="article"] .article-prose > * + *{margin-top:1.1em;}
body[data-page="article"] .article-prose h2{font-weight:600; font-size:26px; line-height:1.25; letter-spacing:-.01em; color:var(--basalt); margin-top:1.6em;}
body[data-page="article"] .article-prose h3{font-weight:600; font-size:20px; line-height:1.3; color:var(--basalt); margin-top:1.4em;}
body[data-page="article"] .article-prose a{text-decoration:underline; text-underline-offset:3px; text-decoration-color:var(--mist);}
body[data-page="article"] .article-prose img{max-width:100%; height:auto; border-radius:var(--r); margin-block:.4em;}
body[data-page="article"] .article-prose blockquote{
  font-family:var(--font-serif); font-weight:320; font-size:clamp(22px,2.4vw,30px);
  line-height:1.2; letter-spacing:-.01em; color:var(--basalt); padding-left:.7em;
  border-left:2px solid var(--ice);
}
body[data-page="article"] .article-prose ul,body[data-page="article"] .article-prose ol{padding-left:1.2em;}
body[data-page="article"] .article-prose li{margin-top:.5em;}
body[data-page="article"] .article-back{margin-top:clamp(40px,5vh,64px); display:inline-flex;}
</style>

<article class="section article-head">
  <div class="container">
    <p class="eyebrow" data-reveal>{{ blog.title | default: 'Journal' }}</p>
    <h1 class="d-l" style="margin-top:16px;" data-reveal>{{ article.title }}</h1>
    <div class="article-meta" data-reveal>
      <span class="coord">{{ article.published_at | date: '%d %b %Y' }}</span>
      {%- if article.author != blank -%}<span class="coord">{{ article.author }}</span>{%- endif -%}
    </div>
    <div class="article-prose" data-reveal>
      {{ article.content }}
    </div>
    <a class="link-arrow article-back" href="{{ blog.url }}">Back to {{ blog.title | default: 'the journal' }} <span class="arr">→</span></a>
  </div>
</article>

{% schema %}
{"name":"Article","settings":[]}
{% endschema %}
