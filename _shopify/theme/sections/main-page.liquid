<style>
body[data-page="page"] .page-hero{padding-top:calc(var(--nav-h) + clamp(40px,7vh,72px));}
body[data-page="page"] .page-prose{max-width:66ch; margin-top:clamp(32px,5vh,52px); color:var(--slate); font-size:17px; line-height:1.7;}
body[data-page="page"] .page-prose > * + *{margin-top:1.1em;}
body[data-page="page"] .page-prose h2{font-weight:600; font-size:26px; line-height:1.25; letter-spacing:-.01em; color:var(--basalt); margin-top:1.6em;}
body[data-page="page"] .page-prose h3{font-weight:600; font-size:20px; line-height:1.3; color:var(--basalt); margin-top:1.4em;}
body[data-page="page"] .page-prose a{text-decoration:underline; text-underline-offset:3px; text-decoration-color:var(--mist);}
body[data-page="page"] .page-prose img{max-width:100%; height:auto; border-radius:var(--r);}
body[data-page="page"] .page-prose ul,body[data-page="page"] .page-prose ol{padding-left:1.2em;}
body[data-page="page"] .page-prose li{margin-top:.5em;}
</style>

<section class="section page-hero" aria-label="{{ page.title | escape }}">
  <div class="container">
    <p class="eyebrow" data-reveal>Page</p>
    <h1 class="d-l" style="margin-top:16px;" data-reveal>{{ page.title }}</h1>
    <div class="page-prose" data-reveal>
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{"name":"Page","settings":[]}
{% endschema %}
